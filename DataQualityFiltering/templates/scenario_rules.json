        "如果没有随访计划 → 扣分"
      ],
      "scenario_specific_focus": [
        "治疗目标设定",
        "生活方式干预",
        "药物管理",
        "定期随访"
      ]
    },
    "LIFESTYLE_ADVICE": {
      "mandatory_checks": [
